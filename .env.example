# Database Configuration
DATABASE_URL=postgresql://crm_user:crm_password@localhost:5432/ai_crm

# LLM API Keys
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Redis (for caching and message queue)
REDIS_URL=redis://localhost:6379/0

# Email Integration
GMAIL_API_CREDENTIALS=credentials/gmail_credentials.json

# Calendar Integration
GOOGLE_CALENDAR_CREDENTIALS=credentials/calendar_credentials.json

# Application Settings
DEBUG=True
SECRET_KEY=your-secret-key-generate-a-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Agent Configuration
LEAD_QUALIFICATION_ENABLED=true
EMAIL_INTELLIGENCE_ENABLED=true
SALES_PIPELINE_ENABLED=true
CUSTOMER_SUCCESS_ENABLED=true
MEETING_SCHEDULER_ENABLED=true
ANALYTICS_ENABLED=true

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=your-sentry-dsn-if-using

# API Rate Limits
RATE_LIMIT_PER_MINUTE=100
