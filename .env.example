# Mailtrap Email Configuration
# ==========================================
# Option 1: Mailtrap Email Sending (API mode) - Recommended
# Get your API key from: https://mailtrap.io -> Email Sending -> API Keys
MAILTRAP_API_KEY=your_api_key_here
MAILTRAP_API_HOST=send.api.mailtrap.io
MAILTRAP_FROM_EMAIL=noreply@yourdomain.com

# Option 2: Mailtrap Email Testing (SMTP mode) - For testing only
# Get SMTP credentials from: https://mailtrap.io -> Email Testing -> Inboxes
# MAILTRAP_SMTP_HOST=smtp.mailtrap.io
# MAILTRAP_SMTP_PORT=587
# MAILTRAP_USERNAME=your_smtp_username
# MAILTRAP_PASSWORD=your_smtp_password
